#include <stdio.h>

int main(){
    float nota1, nota2, nota3, media;

    printf("Digite as tres notas: ");
    scanf("%f%f%f", &nota1, &nota2, &nota3);

    media = ((nota1 * 2) + (nota2 * 3) + (nota3 * 5)) / 10;

    if (media >= 7)
        printf("APROVADO");

    else if (media >= 5 && media < 7)
        printf("RECUPERACAO");

    else
        printf("REPROVADO");

    return 0;
}
