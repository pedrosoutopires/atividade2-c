#include <stdio.h>

int verificardiasmes(int mes, int ano){
    int dias;

    switch (mes) {

    case 1:
    case 3:
    case 5:
    case 7:
    case 8:
    case 10:
    case 12:
        dias = 31;
        break;
    case 4:
    case 6:
    case 9:
    case 11:
        dias = 30;
        break;
    case 2:
        if (ano % 4 == 0){
            dias = 29;
        }else {
            dias = 28;
}
        break;
    }

    return dias;
}

int main(){

    int mes, ano;

    printf("digite o mes: ");
    scanf("%d", &mes);
    printf("digite o ano: ");
    scanf("%d", &ano);

    printf("%d", verificardiasmes(mes, ano));

    return 0;

}
