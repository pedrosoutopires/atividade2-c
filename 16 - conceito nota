#include <stdio.h>

char conceitofinal(float nota) {
    char conceito;

    if(nota < 60)
        conceito = 'F';

    else if(nota >= 60 && nota < 70)
        conceito = 'D';

        else if(nota >= 70 && nota < 80)
        conceito = 'C';

        else if (nota >= 80 && nota < 90)
        conceito = 'B';

        else
        conceito = 'A';


    return conceito;
}

int main(){

    float nota;

    printf("Digite a nota: ");
    scanf("%f", &nota);

    printf("%c", conceitofinal(nota));

    return 0;
}
