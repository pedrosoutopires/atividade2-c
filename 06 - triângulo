#include <stdio.h>

int main() {
    float x, y, z;

    printf("Digite os tres lados do triangulo: ");
    scanf("%f%f%f", &x, &y, &z);

    if(x < y + z && y < x + z && z < x + y) {

        if(x == y && y == z)
            printf("Triangulo EQUILATERO");

        else if(x == y || x == z || y == z)
            printf("Triangulo ISOSCELES");

        else
            printf("Triangulo ESCALENO");

    } else {
        printf("Os valores nao formam um triangulo");
    }

    return 0;
}
